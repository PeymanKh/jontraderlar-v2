# =============================================================================
# Jön Traderlar v2 — Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.
# Nested settings use double underscores (e.g. TELEGRAM__BOT_TOKEN).
# =============================================================================

# --- Application ----------------------------------------------------------
APP_NAME=jontraderlar
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON=false

# --- HTTP gateway ---------------------------------------------------------
HOST=0.0.0.0
PORT=8080
PUBLIC_URL=https://bot.example.com

# --- Telegram -------------------------------------------------------------
TELEGRAM__BOT_TOKEN=000000:replace-with-real-bot-token
TELEGRAM__ADMIN_CHAT_ID=-1000000000000
TELEGRAM__GROUP_ID=-1000000000000
TELEGRAM__WEBHOOK_SECRET=change-me-to-a-long-random-string

# --- Redis (queue + ARQ) --------------------------------------------------
REDIS__HOST=127.0.0.1
REDIS__PORT=6379
REDIS__DATABASE=0
REDIS__PASSWORD=

# --- MongoDB --------------------------------------------------------------
DATABASE__URI=mongodb://localhost:27017
DATABASE__NAME=verificationSystem
DATABASE__CHECKPOINT_NAME=verificationSystemStates

# --- LLM provider ---------------------------------------------------------
MODEL__PROVIDER=google
MODEL__MODEL_NAME=gemini-2.5-flash
MODEL__API_KEY=your-api-key-here
MODEL__TEMPERATURE=0.7

# --- BingX ----------------------------------------------------------------
BINGX__API_KEY=your-bingx-api-key
BINGX__SECRET_KEY=your-bingx-secret-key

# --- ByBit ----------------------------------------------------------------
BYBIT__API_KEY=your-bybit-api-key
BYBIT__SECRET_KEY=your-bybit-secret-key

# --- Business rules -------------------------------------------------------
# Comma-separated UIDs that should be rejected (e.g. Hirozaki's own UIDs).
BLOCKED_UIDS=10485956,725970
